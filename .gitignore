# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# parallel-orchestra isolated worktrees
.po-worktrees/

# parallel-orchestra run-state files (contain absolute paths and task IDs)
.po-run-state-*.json

# parallel-orchestra runtime debug logs (per-task stdout/stderr; merge target none)
.claude/logs/*.log

# C3 session telemetry (parent-session local; not meant to merge)
.claude/memory/sessions/*.tmp
.claude/memory/agent-debug.log

# Environment variables
.env
.env.*

# Examples / local testing artifacts (not committed)
examples/
