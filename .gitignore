# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# parallel-orchestra isolated worktrees
.po-worktrees/

# parallel-orchestra run-state files (contain absolute paths and task IDs)
.po-run-state-*.json

# parallel-orchestra runtime debug logs (per-task stdout/stderr; merge target none)
.claude/logs/*.log

# Optional: framework-specific runtime artifacts under .claude/.
# The patterns below are required when running this project alongside the C3
# framework, which writes per-session telemetry into .claude/memory/. Adjust
# or remove these entries to match whatever framework (if any) you pair with
# parallel-orchestra.
.claude/memory/sessions/*.tmp
.claude/memory/agent-debug.log

# Environment variables
.env
.env.*

# Examples / local testing artifacts (not committed)
examples/
